# Сайт (российский VPS)
# Скопируйте: cp .env.site.example .env.site
# Запуск: npm run start:site  |  systemctl restart ai-tg-site

TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# Если RU не достучится до api.telegram.org — Squid на NL (см. deploy/BOT-NL-VPS.md § шаг 8):
# TELEGRAM_API_PROXY=http://NL_VPS_IP:3128

# Postgres на сервере бота (замените BOT_VPS_IP и пароль)
DATABASE_URL=postgresql://postgres:password@BOT_VPS_IP:5432/ai_tg_bot

# OpenAI сайту не нужен
AI_PROVIDER=mock

# ЮKassa — webhook на этом сервере (прокси не нужен)
YOOKASSA_SHOP_ID=123456
YOOKASSA_SECRET_KEY=live_...
YOOKASSA_RETURN_URL=https://t.me/YourBot
YOOKASSA_RECEIPT_EMAIL=receipts@yourdomain.com

PAYMENT_SUPPORT_USERNAME=@yakovlev_dev
ADMIN_TELEGRAM_IDS=123456789

# Часовой пояс админки и отчётов (Europe/Moscow по умолчанию)
APP_TIMEZONE=Europe/Moscow

# HTTP только на localhost — снаружи nginx
ADMIN_WEB_HOST=127.0.0.1
ADMIN_WEB_PORT=3080
ADMIN_WEB_USER=admin
ADMIN_WEB_PASSWORD=change_me_strong_password

PUBLIC_SITE_NAME=Код личности
PUBLIC_SITE_TAGLINE=Разбор по уникальной системе. Узнай себя и пойди по истинному пути.
PUBLIC_BOT_USERNAME=YourBotUsername
PUBLIC_SITE_URL=https://personality-code.ru
PRIVACY_POLICY_URL=https://personality-code.ru/privacy
COOKIES_POLICY_URL=https://personality-code.ru/cookies
PRIVACY_POLICY_UPDATED=13.06.2025
PRIVACY_POLICY_FILE=prompts/privacy-policy.txt
COOKIES_POLICY_FILE=prompts/cookies-policy.txt

# Тарифы на лендинге — должны совпадать с .env.bot
TOPUP_PACKAGES=111:5,199:10,300:20
