# Бот (зарубежный VPS: VDSina и т.п.)
# Скопируйте: cp .env.bot.example .env.bot
# Запуск: npm run start:bot  |  systemctl restart ai-tg-bot

TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Postgres на этом же сервере (localhost)
DATABASE_URL=postgresql://postgres:password@127.0.0.1:5432/ai_tg_bot

AI_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini

# ЮKassa — создание платежей из бота
YOOKASSA_SHOP_ID=123456
YOOKASSA_SECRET_KEY=live_...
YOOKASSA_RETURN_URL=https://t.me/YourBot
YOOKASSA_RECEIPT_EMAIL=receipts@yourdomain.com
# Если сервер не в РФ — прокси до api.yookassa.ru:
# YOOKASSA_PROXY=http://user:pass@ru-proxy:3128

PAYMENT_SUPPORT_USERNAME=@yakovlev_dev
ADMIN_TELEGRAM_IDS=123456789

# Ссылки в боте (сайт на RU VPS, URL тот же)
PUBLIC_SITE_NAME=Код личности
PUBLIC_BOT_USERNAME=YourBotUsername
PUBLIC_SITE_URL=https://personality-code.ru
PRIVACY_POLICY_URL=https://personality-code.ru/privacy
COOKIES_POLICY_URL=https://personality-code.ru/cookies
WELCOME_MESSAGE_FILE=prompts/welcome.txt

REQUESTS_PER_MESSAGE=1
WELCOME_BONUS_REQUESTS=1
TOPUP_PACKAGES=200:5,300:10,500:20
ADMIN_TOPUP_PACKAGE=1:10

MESSAGE_COOLDOWN_MS=2000
MAX_MESSAGE_LENGTH=4000
HISTORY_LIMIT=20
ONBOARDING_DELAY_MS=5000
ONBOARDING_CALCULATION_DELAY_MS=10000
QUESTION_THINKING_DELAY_MS=4000
POST_ANSWER_FOLLOWUP_DELAY_MS=5000
LOW_TOKENS_TARIFFS_THRESHOLD=4

# Закрытый доступ к боту (опционально)
# BOT_ACCESS_PASSWORD=your_secret_password

# Сайт на этом сервере не запускаем — ADMIN_WEB_* не нужны
