TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Раздельные env для бота и сайта (см. .env.bot.example и .env.site.example):
#   npm run start:bot   → .env.bot
#   npm run start:site  → .env.site
#   npm run dev         → .env (оба в одном процессе, локально)

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_tg_bot

# mock — без OpenAI, openai — реальный API
AI_PROVIDER=mock
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini

# Биллинг: 1 вопрос за ответ. Тарифы: рубли:кол-во вопросов
REQUESTS_PER_MESSAGE=1
WELCOME_BONUS_REQUESTS=1
TOPUP_PACKAGES=200:5,300:10,500:20
# Кнопка «Тарифы» под ответом, если осталось вопросов меньше порога
LOW_TOKENS_TARIFFS_THRESHOLD=3
# Тестовый тариф только для ADMIN_TELEGRAM_IDS (off — отключить)
ADMIN_TOPUP_PACKAGE=1:10

# ЮKassa (обязательно)
YOOKASSA_SHOP_ID=123456
YOOKASSA_SECRET_KEY=live_...
# Куда вернуть пользователя после оплаты (ссылка на бота)
YOOKASSA_RETURN_URL=https://t.me/YourBot
# Обязательно, если в кабинете включены чеки 54-ФЗ:
# YOOKASSA_RECEIPT_EMAIL=receipts@yourdomain.com
# YOOKASSA_VAT_CODE=1
# YOOKASSA_SEND_RECEIPT=false
# YOOKASSA_SKIP_IP_CHECK=true
# Фоновая проверка статуса, если webhook не дошёл (интервал мс, число попыток ≈ 5 мин)
# YOOKASSA_POLL_INTERVAL_MS=15000
# YOOKASSA_POLL_MAX_ATTEMPTS=20
# Если сервер не в РФ — ЮKassa режет запросы к своему API по IP.
# Пустишь запросы через российский HTTP(S)-прокси:
# YOOKASSA_PROXY=http://user:pass@host:port
PAYMENT_SUPPORT_USERNAME=@yakovlev_dev

# Telegram ID админов через запятую (расширенные команды бота и тестовый тариф)
ADMIN_TELEGRAM_IDS=123456789

# Любой свободный порт (3000 часто занят другими приложениями)
ADMIN_WEB_HOST=127.0.0.1
ADMIN_WEB_PORT=3080
ADMIN_WEB_USER=admin
ADMIN_WEB_PASSWORD=change_me_strong_password

# Лендинг (главная страница на /) и политика (/privacy)
PUBLIC_SITE_NAME=Код личности
PUBLIC_SITE_TAGLINE=Персональный код личности в Telegram: астрология, Human Design, нумерология, Сюцай и ведическая астрология.
PUBLIC_BOT_USERNAME=YourBotUsername
PUBLIC_SITE_URL=https://your-domain.com
# Оператор в политике ПДн (по умолчанию — PUBLIC_SITE_NAME)
# PRIVACY_OPERATOR_NAME=ИП Иванов И.И.
# PRIVACY_POLICY_UPDATED=13.06.2025
# PRIVACY_POLICY_FILE=prompts/privacy-policy.txt

# Пауза между шагами анкеты после /start (мс)
ONBOARDING_DELAY_MS=5000
# Пауза при расчёте кода личности — бот «думает» (мс)
ONBOARDING_CALCULATION_DELAY_MS=15000

# Пауза после мистического пролога перед ответом на вопрос (мс)
QUESTION_THINKING_DELAY_MS=4000
# Пауза перед предложением задать следующий вопрос (мс)
POST_ANSWER_FOLLOWUP_DELAY_MS=5000

#Лимиты чата
MESSAGE_COOLDOWN_MS=2000
MAX_MESSAGE_LENGTH=4000
HISTORY_LIMIT=20

# Промпт кода личности: prompts/code.txt
# Приветствие на /start. Плейсхолдеры: {packages}, {welcome_bonus_line}, {requests_per_message}, {privacy_policy_url}
# {privacy_policy_url} — кликабельная ссылка «Политикой обработки персональных данных» (HTML)
WELCOME_MESSAGE_FILE=prompts/welcome.txt
# Ссылка на политику в боте (если пусто — PUBLIC_SITE_URL/privacy)
PRIVACY_POLICY_URL=https://your-domain.com/privacy
# Политика cookie на сайте (/cookies)
COOKIES_POLICY_URL=https://your-domain.com/cookies
# COOKIES_POLICY_UPDATED=13.06.2025
# COOKIES_POLICY_FILE=prompts/cookies-policy.txt

# Системный промпт для ответов на вопросы после анкеты (необязательно):
# SYSTEM_PROMPT_FILE=prompts/system.txt
