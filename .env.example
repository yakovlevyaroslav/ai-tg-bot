TELEGRAM_BOT_TOKEN=your_telegram_bot_token
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_tg_bot

# mock — без OpenAI, openai — реальный API
AI_PROVIDER=mock
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini

# Кредиты: 100 ₽ = 1000 кредитов (10 кредитов за 1 ₽)
CREDITS_PER_RUB=10
CREDITS_PER_MESSAGE=10
WELCOME_BONUS_CREDITS=300
TOPUP_PACKAGES_RUB=100,300,500,1000

PAYMENT_DETAILS=Перевод на карту. Укажите код оплаты в комментарии.
PAYMENT_SUPPORT_USERNAME=@your_support

ADMIN_TELEGRAM_IDS=123456789

# Любой свободный порт (3000 часто занят другими приложениями)
ADMIN_WEB_PORT=3080
ADMIN_WEB_USER=admin
ADMIN_WEB_PASSWORD=change_me_strong_password

MESSAGE_COOLDOWN_MS=2000
MAX_MESSAGE_LENGTH=4000
HISTORY_LIMIT=20

# Промпты специалистов: prompts/specialists/tarolog.txt, numerolog.txt, rodolog.txt
# SYSTEM_PROMPT / SYSTEM_PROMPT_FILE — запасной вариант, если файл специалиста не найден
