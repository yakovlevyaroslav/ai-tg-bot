TELEGRAM_BOT_TOKEN=your_telegram_bot_token
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_tg_bot

# mock — без OpenAI, openai — реальный API
AI_PROVIDER=mock
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini

# Кредиты: 100 ₽ = 1000 кредитов (10 кредитов за 1 ₽)
CREDITS_PER_RUB=10
CREDITS_PER_MESSAGE=10
WELCOME_BONUS_CREDITS=300
TOPUP_PACKAGES_RUB=1,100,500,1000

# instant — сразу начисляет кредиты (для разработки)
# manual — перевод + /confirm, yookassa — оплата через ЮKassa
PAYMENT_PROVIDER=instant

PAYMENT_DETAILS=Перевод на карту. Укажите код оплаты в комментарии.

# ЮKassa (если PAYMENT_PROVIDER=yookassa)
# YOOKASSA_SHOP_ID=123456
# YOOKASSA_SECRET_KEY=live_...
# Куда вернуть пользователя после оплаты (ссылка на бота)
# YOOKASSA_RETURN_URL=https://t.me/ObormotMusoroglot_bot
# Обязательно, если в кабинете включены чеки 54-ФЗ:
# YOOKASSA_RECEIPT_EMAIL=receipts@yourdomain.com
# YOOKASSA_VAT_CODE=1
# YOOKASSA_SEND_RECEIPT=false
# YOOKASSA_SKIP_IP_CHECK=true
PAYMENT_SUPPORT_USERNAME=@your_support

ADMIN_TELEGRAM_IDS=123456789

# Любой свободный порт (3000 часто занят другими приложениями)
ADMIN_WEB_HOST=127.0.0.1
ADMIN_WEB_PORT=3080
ADMIN_WEB_USER=admin
ADMIN_WEB_PASSWORD=change_me_strong_password

# Лендинг (главная страница на /)
PUBLIC_SITE_NAME=Obormot Musoroglot
PUBLIC_BOT_USERNAME=ObormotMusoroglot_bot
PUBLIC_SITE_URL=https://your-domain.com

MESSAGE_COOLDOWN_MS=2000
MAX_MESSAGE_LENGTH=4000
HISTORY_LIMIT=20

# Промпты специалистов (в git): prompts/specialists/tarolog.txt, numerolog.txt, rodolog.txt
# Запасной промпт — необязательно; если файла нет, используется текст по умолчанию:
# SYSTEM_PROMPT_FILE=prompts/system.txt
